# Kamernet Radar dashboard — local config.
# Copy this file to `.env.local` and fill in the values you need.

# Postgres connection string. Point this at the same database the scraper writes to.
# Docker compose default:
DATABASE_URL=postgres://radar:radar@localhost:5432/radar

# OPTIONAL: require a password to view the dashboard.
# If set, every route is gated behind a /login form. Cookie lasts 30 days.
# If unset, the dashboard is fully open (fine for a trusted local setup).
# Pick something long. The cookie stores this value on the user's browser, so
# don't reuse a password from elsewhere.
# DASHBOARD_PASSWORD=
