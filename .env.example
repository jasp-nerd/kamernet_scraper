# ─────────────────────────────────────────────────────────────────────
# Kamernet Radar scraper configuration
# Copy this file to `.env` and fill in the values you need.
# Each value below is optional unless marked REQUIRED.
# ─────────────────────────────────────────────────────────────────────

# ── Profile ─────────────────────────────────────────────────────────
# Which scoring profile to use. Pick a built-in name from the profiles/
# folder, or point at an absolute path to a YAML file you wrote yourself.
#   Built-ins: generic, student-amsterdam, young-professional-randstad, family-utrecht
PROFILE=generic


# ── Database (REQUIRED for persistence, Telegram subscribers, dashboard) ──
# Leave unset to run the scraper without persistence. It will fetch and
# print results, but won't remember what it's seen.
DATABASE_URL=postgres://radar:radar@localhost:5432/radar


# ── AI scoring via OpenRouter ───────────────────────────────────────
# Get a free key at https://openrouter.ai. Many models have a free tier.
# Leave unset to skip AI scoring entirely.
OPENROUTER_API_KEY=
# Primary model (must support structured JSON output)
OPENROUTER_MODEL=openai/gpt-oss-120b:free
# Fallback if the primary rate-limits or errors
OPENROUTER_FALLBACK_MODEL=deepseek/deepseek-v3.2


# ── Notifications: Discord (native rich embeds) ─────────────────────
# Create a webhook in your server: Server Settings → Integrations → Webhooks.
# Leave unset to skip Discord notifications.
DISCORD_WEBHOOK_URL=


# ── Notifications: Telegram (native subscriber flow) ────────────────
# Create a bot: message @BotFather on Telegram, use /newbot, copy the token.
# Users subscribe by sending /start <password> to your bot.
# Both variables are required together. Radar refuses to run a passwordless public bot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_PASSWORD=
# Minimum AI score (0-100) to notify Telegram subscribers. Listings below
# this threshold go to the DB without pinging subscribers.
TELEGRAM_SCORE_THRESHOLD=80


# ── Notifications: Apprise (100+ channels via a single URL) ─────────
# Comma-separated list of Apprise URLs. Any channel: Slack, ntfy, email,
# Pushover, Matrix, WhatsApp via Twilio.
# Syntax: https://github.com/caronc/apprise/wiki
# Examples:
#   APPRISE_URLS=ntfy://my-private-topic
#   APPRISE_URLS=slack://TokenA/TokenB/TokenC
#   APPRISE_URLS=mailto://user:pass@smtp.gmail.com?to=you@example.com
#   APPRISE_URLS=pover://USER_KEY@APP_TOKEN
#   APPRISE_URLS=ntfy://foo,slack://TokenA/TokenB/TokenC   (multiple at once)
APPRISE_URLS=
# Minimum AI score to send via Apprise. 0 means send everything.
APPRISE_SCORE_THRESHOLD=0


# ── Scheduling ──────────────────────────────────────────────────────
# Seconds between checks (randomized in this range to avoid pattern detection).
CHECK_INTERVAL_MIN=50
CHECK_INTERVAL_MAX=70


# ── User agent ──────────────────────────────────────────────────────
# Identify your scraper to Kamernet. Include contact info so they can reach
# you if something breaks. Standard web-scraping courtesy.
USER_AGENT=Mozilla/5.0 (compatible; KamernetRadar/1.0; +https://github.com/YOUR_USERNAME/kamernet-radar)
